{
  "$defs": {
    "Candidate": {
      "additionalProperties": false,
      "properties": {
        "causal_chain": {
          "items": {
            "type": "string"
          },
          "title": "Causal Chain",
          "type": "array"
        },
        "company_name": {
          "title": "Company Name",
          "type": "string"
        },
        "confidence_label": {
          "$ref": "#/$defs/ConfidenceLabel",
          "default": "medium"
        },
        "counterarguments": {
          "items": {
            "type": "string"
          },
          "title": "Counterarguments",
          "type": "array"
        },
        "direct_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Direct Evidence",
          "type": "array"
        },
        "disconfirming_conditions": {
          "items": {
            "type": "string"
          },
          "title": "Disconfirming Conditions",
          "type": "array"
        },
        "event_ids": {
          "items": {
            "type": "string"
          },
          "title": "Event Ids",
          "type": "array"
        },
        "evidence_quality": {
          "$ref": "#/$defs/ConfidenceLabel",
          "default": "medium"
        },
        "inferred_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Inferred Evidence",
          "type": "array"
        },
        "market_memory_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Market Memory Evidence",
          "type": "array"
        },
        "memory_episode_ids": {
          "items": {
            "type": "string"
          },
          "title": "Memory Episode Ids",
          "type": "array"
        },
        "memory_record_ids": {
          "items": {
            "type": "string"
          },
          "title": "Memory Record Ids",
          "type": "array"
        },
        "novel_reasoning": {
          "default": "",
          "title": "Novel Reasoning",
          "type": "string"
        },
        "path_type": {
          "$ref": "#/$defs/PathType"
        },
        "prior_negative_cases": {
          "items": {
            "type": "string"
          },
          "title": "Prior Negative Cases",
          "type": "array"
        },
        "prior_negative_record_ids": {
          "items": {
            "type": "string"
          },
          "title": "Prior Negative Record Ids",
          "type": "array"
        },
        "prior_positive_cases": {
          "items": {
            "type": "string"
          },
          "title": "Prior Positive Cases",
          "type": "array"
        },
        "prior_positive_record_ids": {
          "items": {
            "type": "string"
          },
          "title": "Prior Positive Record Ids",
          "type": "array"
        },
        "provenance": {
          "items": {
            "$ref": "#/$defs/Provenance"
          },
          "title": "Provenance",
          "type": "array"
        },
        "rank": {
          "title": "Rank",
          "type": "integer"
        },
        "source_urls": {
          "items": {
            "type": "string"
          },
          "title": "Source Urls",
          "type": "array"
        },
        "thesis": {
          "title": "Thesis",
          "type": "string"
        },
        "ticker": {
          "title": "Ticker",
          "type": "string"
        },
        "why_now": {
          "title": "Why Now",
          "type": "string"
        }
      },
      "required": [
        "rank",
        "ticker",
        "company_name",
        "path_type",
        "thesis",
        "why_now"
      ],
      "title": "Candidate",
      "type": "object"
    },
    "ClaimStatus": {
      "enum": [
        "tentative",
        "supported",
        "validated",
        "disputed",
        "retired"
      ],
      "title": "ClaimStatus",
      "type": "string"
    },
    "ConfidenceLabel": {
      "enum": [
        "very_high",
        "high",
        "medium",
        "low",
        "speculative"
      ],
      "title": "ConfidenceLabel",
      "type": "string"
    },
    "EventTickerEdge": {
      "additionalProperties": false,
      "properties": {
        "company_name": {
          "title": "Company Name",
          "type": "string"
        },
        "confidence_label": {
          "$ref": "#/$defs/ConfidenceLabel",
          "default": "medium"
        },
        "directly_mentioned": {
          "title": "Directly Mentioned",
          "type": "boolean"
        },
        "edge_id": {
          "title": "Edge Id",
          "type": "string"
        },
        "episode_id": {
          "title": "Episode Id",
          "type": "string"
        },
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "fundamental_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Fundamental Evidence",
          "type": "array"
        },
        "market_memory_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Market Memory Evidence",
          "type": "array"
        },
        "narrative_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Narrative Evidence",
          "type": "array"
        },
        "provenance": {
          "items": {
            "$ref": "#/$defs/Provenance"
          },
          "title": "Provenance",
          "type": "array"
        },
        "relation_class": {
          "$ref": "#/$defs/RelationClass"
        },
        "relation_explanation": {
          "title": "Relation Explanation",
          "type": "string"
        },
        "temporal_validity": {
          "title": "Temporal Validity",
          "type": "string"
        },
        "ticker": {
          "title": "Ticker",
          "type": "string"
        }
      },
      "required": [
        "edge_id",
        "episode_id",
        "event_id",
        "ticker",
        "company_name",
        "relation_class",
        "relation_explanation",
        "directly_mentioned",
        "temporal_validity"
      ],
      "title": "EventTickerEdge",
      "type": "object"
    },
    "MemoryClaim": {
      "additionalProperties": false,
      "properties": {
        "available_from": {
          "format": "date-time",
          "title": "Available From",
          "type": "string"
        },
        "claim_id": {
          "title": "Claim Id",
          "type": "string"
        },
        "conditions": {
          "items": {
            "type": "string"
          },
          "title": "Conditions",
          "type": "array"
        },
        "confidence_label": {
          "$ref": "#/$defs/ConfidenceLabel",
          "default": "medium"
        },
        "contradiction_episode_ids": {
          "items": {
            "type": "string"
          },
          "title": "Contradiction Episode Ids",
          "type": "array"
        },
        "failure_modes": {
          "items": {
            "type": "string"
          },
          "title": "Failure Modes",
          "type": "array"
        },
        "first_observed_at": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "First Observed At"
        },
        "last_updated_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Last Updated At"
        },
        "mechanism": {
          "title": "Mechanism",
          "type": "string"
        },
        "near_miss_episode_ids": {
          "items": {
            "type": "string"
          },
          "title": "Near Miss Episode Ids",
          "type": "array"
        },
        "provenance": {
          "items": {
            "$ref": "#/$defs/Provenance"
          },
          "title": "Provenance",
          "type": "array"
        },
        "scope": {
          "title": "Scope",
          "type": "string"
        },
        "statement": {
          "title": "Statement",
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/ClaimStatus",
          "default": "tentative"
        },
        "support_episode_ids": {
          "items": {
            "type": "string"
          },
          "title": "Support Episode Ids",
          "type": "array"
        }
      },
      "required": [
        "claim_id",
        "statement",
        "mechanism",
        "scope",
        "available_from"
      ],
      "title": "MemoryClaim",
      "type": "object"
    },
    "NewsItem": {
      "additionalProperties": false,
      "properties": {
        "body": {
          "title": "Body",
          "type": "string"
        },
        "collected_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Collected At"
        },
        "event_id": {
          "title": "Event Id",
          "type": "string"
        },
        "provenance": {
          "items": {
            "$ref": "#/$defs/Provenance"
          },
          "title": "Provenance",
          "type": "array"
        },
        "published_at": {
          "format": "date-time",
          "title": "Published At",
          "type": "string"
        },
        "row_number": {
          "title": "Row Number",
          "type": "integer"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "event_id",
        "row_number",
        "published_at",
        "title",
        "body",
        "source_id"
      ],
      "title": "NewsItem",
      "type": "object"
    },
    "PathType": {
      "enum": [
        "SINGLE_EVENT",
        "THEME_BENEFICIARY",
        "CONTINUATION",
        "HYBRID"
      ],
      "title": "PathType",
      "type": "string"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "content_sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Sha256"
        },
        "excerpt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Excerpt"
        },
        "observed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed At"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "source_type": {
          "title": "Source Type",
          "type": "string"
        },
        "uri": {
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "source_type",
        "uri"
      ],
      "title": "Provenance",
      "type": "object"
    },
    "RelationClass": {
      "enum": [
        "DIRECT",
        "FUNDAMENTAL",
        "MARKET_MEMORY",
        "CONTINUATION",
        "INFERRED_NEW"
      ],
      "title": "RelationClass",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "LLM-produced draft used to convert free-form research into a canonical episode.",
  "properties": {
    "available_from": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Available From"
    },
    "blind_predictions": {
      "items": {
        "$ref": "#/$defs/Candidate"
      },
      "title": "Blind Predictions",
      "type": "array"
    },
    "counterexamples": {
      "items": {
        "$ref": "#/$defs/MemoryClaim"
      },
      "title": "Counterexamples",
      "type": "array"
    },
    "cutoff_at": {
      "format": "date-time",
      "title": "Cutoff At",
      "type": "string"
    },
    "event_ticker_edges": {
      "items": {
        "$ref": "#/$defs/EventTickerEdge"
      },
      "title": "Event Ticker Edges",
      "type": "array"
    },
    "initial_uncertainties": {
      "items": {
        "type": "string"
      },
      "title": "Initial Uncertainties",
      "type": "array"
    },
    "input_news_files": {
      "items": {
        "type": "string"
      },
      "title": "Input News Files",
      "type": "array"
    },
    "input_news_hashes": {
      "items": {
        "type": "string"
      },
      "title": "Input News Hashes",
      "type": "array"
    },
    "lessons": {
      "items": {
        "$ref": "#/$defs/MemoryClaim"
      },
      "title": "Lessons",
      "type": "array"
    },
    "misses": {
      "items": {
        "type": "string"
      },
      "title": "Misses",
      "type": "array"
    },
    "observed_events": {
      "items": {
        "$ref": "#/$defs/NewsItem"
      },
      "title": "Observed Events",
      "type": "array"
    },
    "open_world_mechanisms": {
      "items": {
        "type": "string"
      },
      "title": "Open World Mechanisms",
      "type": "array"
    },
    "price_source_snapshot": {
      "additionalProperties": true,
      "title": "Price Source Snapshot",
      "type": "object"
    },
    "research_version": {
      "default": "semantic-llm-v1",
      "title": "Research Version",
      "type": "string"
    },
    "schema_version": {
      "default": "nslab.semantic_research_draft.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "summary": {
      "title": "Summary",
      "type": "string"
    },
    "trade_date": {
      "format": "date",
      "title": "Trade Date",
      "type": "string"
    }
  },
  "required": [
    "trade_date",
    "cutoff_at",
    "summary",
    "open_world_mechanisms"
  ],
  "title": "SemanticResearchDraft",
  "type": "object"
}
