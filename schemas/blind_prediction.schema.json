      "type": "string"
    },
    "DominantSectorHypothesis": {
      "additionalProperties": false,
      "properties": {
        "contradicting_cases": {
          "items": {
            "type": "string"
          },
          "title": "Contradicting Cases",
          "type": "array"
        },
        "contradicting_record_ids": {
          "items": {
            "type": "string"
          },
          "title": "Contradicting Record Ids",
          "type": "array"
        },
        "direct_beneficiaries": {
          "items": {
            "type": "string"
          },
          "title": "Direct Beneficiaries",
          "type": "array"
        },
        "expected_breadth": {
          "title": "Expected Breadth",
          "type": "string"
        },
        "failure_conditions": {
          "items": {
            "type": "string"
          },
          "title": "Failure Conditions",
          "type": "array"
        },
        "formation_mechanism": {
          "title": "Formation Mechanism",
          "type": "string"
        },
        "indirect_beneficiaries": {
          "items": {
            "type": "string"
          },
          "title": "Indirect Beneficiaries",
          "type": "array"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "narrative_beneficiaries": {
          "items": {
            "type": "string"
          },
          "title": "Narrative Beneficiaries",
          "type": "array"
        },
        "possible_leaders": {
          "items": {
            "type": "string"
          },
          "title": "Possible Leaders",
          "type": "array"
        },
        "provenance": {
          "items": {
            "$ref": "#/$defs/Provenance"
          },
          "title": "Provenance",
          "type": "array"
        },
        "supporting_cases": {
          "items": {
            "type": "string"
          },
          "title": "Supporting Cases",
          "type": "array"
        },
        "supporting_record_ids": {
          "items": {
            "type": "string"
          },
          "title": "Supporting Record Ids",
          "type": "array"
        },
        "triggering_events": {
          "items": {
            "type": "string"
          },
          "title": "Triggering Events",
          "type": "array"
        }
      },
      "required": [
        "name",
        "formation_mechanism",
        "expected_breadth"
      ],
      "title": "DominantSectorHypothesis",
      "type": "object"
    },
    "PathType": {
      "enum": [
        "SINGLE_EVENT",
        "THEME_BENEFICIARY",
        "CONTINUATION",
        "HYBRID"
      ],
      "title": "PathType",
      "type": "string"
    },
    "Provenance": {
      "additionalProperties": false,
      "properties": {
        "content_sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Content Sha256"
        },
        "excerpt": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Excerpt"
        },
        "observed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed At"
        },
        "source_id": {
          "title": "Source Id",
          "type": "string"
        },
        "source_type": {
          "title": "Source Type",
          "type": "string"
        },
        "uri": {
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "source_id",
        "source_type",
        "uri"
      ],
      "title": "Provenance",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "blind_analysis": {
      "$ref": "#/$defs/BlindAnalysis"
    },
    "blind_artifact_sha256": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Blind Artifact Sha256"
    },
    "candidates": {
      "items": {
        "$ref": "#/$defs/Candidate"
      },
      "title": "Candidates",
      "type": "array"
    },
    "context_manifest_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Context Manifest Id"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "cutoff_at": {
      "format": "date-time",
      "title": "Cutoff At",
      "type": "string"
    },
    "dominant_sectors": {
      "items": {
        "$ref": "#/$defs/DominantSectorHypothesis"
      },
      "title": "Dominant Sectors",
      "type": "array"
    },
    "prediction_id": {
      "title": "Prediction Id",
      "type": "string"
    },
    "schema_version": {
      "default": "nslab.blind_prediction.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "sealed_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sealed At"
    },
    "trade_date": {
      "format": "date",
      "title": "Trade Date",
      "type": "string"
    }
  },
  "required": [
    "prediction_id",
    "trade_date",
    "cutoff_at",
    "created_at",
    "blind_analysis"
  ],
  "title": "BlindPrediction",
  "type": "object"
}
