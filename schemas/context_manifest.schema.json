{
  "$defs": {
    "PriceSnapshot": {
      "additionalProperties": false,
      "properties": {
        "allowed_through": {
          "anyOf": [
            {
              "format": "date",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Allowed Through"
        },
        "as_of": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "As Of"
        },
        "notes": {
          "items": {
            "type": "string"
          },
          "title": "Notes",
          "type": "array"
        },
        "source_name": {
          "title": "Source Name",
          "type": "string"
        },
        "source_ref": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Ref"
        }
      },
      "required": [
        "source_name"
      ],
      "title": "PriceSnapshot",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "accepted_episode_count": {
      "title": "Accepted Episode Count",
      "type": "integer"
    },
    "brain_file_hashes": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Brain File Hashes",
      "type": "object"
    },
    "brain_files": {
      "items": {
        "type": "string"
      },
      "title": "Brain Files",
      "type": "array"
    },
    "brain_version": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Brain Version"
    },
    "counterexample_episode_ids": {
      "items": {
        "type": "string"
      },
      "title": "Counterexample Episode Ids",
      "type": "array"
    },
    "errors": {
      "items": {
        "type": "string"
      },
      "title": "Errors",
      "type": "array"
    },
    "memory_sweep_artifacts": {
      "items": {
        "type": "string"
      },
      "title": "Memory Sweep Artifacts",
      "type": "array"
    },
    "memory_sweep_cache_hits": {
      "default": 0,
      "title": "Memory Sweep Cache Hits",
      "type": "integer"
    },
    "memory_sweep_shard_count": {
      "default": 0,
      "title": "Memory Sweep Shard Count",
      "type": "integer"
    },
    "mode": {
      "title": "Mode",
      "type": "string"
    },
    "model_config": {
      "additionalProperties": true,
      "title": "Model Config",
      "type": "object"
    },
    "price_snapshot": {
      "$ref": "#/$defs/PriceSnapshot"
    },
    "prompt_hashes": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Prompt Hashes",
      "type": "object"
    },
    "retrieved_episode_ids": {
      "items": {
        "type": "string"
      },
      "title": "Retrieved Episode Ids",
      "type": "array"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "nslab.context_manifest.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "swept_episode_count": {
      "title": "Swept Episode Count",
      "type": "integer"
    },
    "swept_episode_ids": {
      "items": {
        "type": "string"
      },
      "title": "Swept Episode Ids",
      "type": "array"
    },
    "token_counts": {
      "additionalProperties": {
        "type": "integer"
      },
      "title": "Token Counts",
      "type": "object"
    },
    "truncations": {
      "items": {
        "type": "string"
      },
      "title": "Truncations",
      "type": "array"
    },
    "web_queries": {
      "items": {
        "type": "string"
      },
      "title": "Web Queries",
      "type": "array"
    },
    "web_sources": {
      "items": {
        "type": "string"
      },
      "title": "Web Sources",
      "type": "array"
    }
  },
  "required": [
    "run_id",
    "mode",
    "accepted_episode_count",
    "swept_episode_count",
    "price_snapshot"
  ],
  "title": "ContextManifest",
  "type": "object"
}
