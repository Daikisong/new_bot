      },
      "title": "Notes",
      "type": "array"
    },
    "prompt_sha256": {
      "title": "Prompt Sha256",
      "type": "string"
    },
    "prompt_version": {
      "title": "Prompt Version",
      "type": "string"
    },
    "required_paths": {
      "items": {
        "$ref": "#/$defs/CandidateExpansionPath"
      },
      "title": "Required Paths",
      "type": "array"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "default": "nslab.candidate_expansion.v1",
      "title": "Schema Version",
      "type": "string"
