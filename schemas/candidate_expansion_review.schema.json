        },
        "evidence_source_ids": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Source Ids",
          "type": "array"
        },
        "hypothesis": {
          "title": "Hypothesis",
          "type": "string"
        },
        "investigation_questions": {
          "items": {
            "type": "string"
          },
          "title": "Investigation Questions",
          "type": "array"
        },
        "memory_episode_ids": {
          "items": {
            "type": "string"
          },
          "title": "Memory Episode Ids",
          "type": "array"
        },
        "path": {
          "$ref": "#/$defs/CandidateExpansionPath"
        },
        "related_cluster_ids": {
          "items": {
            "type": "string"
          },
          "title": "Related Cluster Ids",
          "type": "array"
        },
        "requires_web_company_discovery": {
          "default": true,
          "title": "Requires Web Company Discovery",
          "type": "boolean"
