{
  "$defs": {
    "BlindAnalysis": {
      "additionalProperties": false,
      "properties": {
        "excluded_after_cutoff_source_ids": {
          "items": {
            "type": "string"
          },
          "title": "Excluded After Cutoff Source Ids",
          "type": "array"
        },
        "initial_uncertainties": {
          "items": {
            "type": "string"
          },
          "title": "Initial Uncertainties",
          "type": "array"
        },
        "open_world_mechanisms": {
          "items": {
            "type": "string"
          },
          "title": "Open World Mechanisms",
          "type": "array"
        },
        "provenance": {
          "items": {
            "$ref": "#/$defs/Provenance"
          },
          "title": "Provenance",
          "type": "array"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "summary"
      ],
      "title": "BlindAnalysis",
      "type": "object"
    },
    "Candidate": {
      "additionalProperties": false,
      "properties": {
        "causal_chain": {
          "items": {
            "type": "string"
          },
          "title": "Causal Chain",
          "type": "array"
        },
        "company_name": {
          "title": "Company Name",
          "type": "string"
        },
        "confidence_label": {
          "$ref": "#/$defs/ConfidenceLabel",
          "default": "medium"
        },
        "counterarguments": {
          "items": {
            "type": "string"
          },
          "title": "Counterarguments",
          "type": "array"
        },
        "direct_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Direct Evidence",
          "type": "array"
        },
        "disconfirming_conditions": {
          "items": {
            "type": "string"
          },
          "title": "Disconfirming Conditions",
          "type": "array"
        },
        "event_ids": {
          "items": {
            "type": "string"
          },
          "title": "Event Ids",
          "type": "array"
        },
        "evidence_quality": {
          "$ref": "#/$defs/ConfidenceLabel",
          "default": "medium"
        },
        "inferred_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Inferred Evidence",
          "type": "array"
        },
        "market_memory_evidence": {
          "items": {
            "type": "string"
          },
          "title": "Market Memory Evidence",
          "type": "array"
        },
        "memory_episode_ids": {
          "items": {
            "type": "string"
          },
          "title": "Memory Episode Ids",
          "type": "array"
        },
        "memory_record_ids": {
          "items": {
            "type": "string"
          },
          "title": "Memory Record Ids",
          "type": "array"
        },
        "novel_reasoning": {
          "default": "",
          "title": "Novel Reasoning",
          "type": "string"
        },
        "path_type": {
          "$ref": "#/$defs/PathType"
        },
        "prior_negative_cases": {
          "items": {
            "type": "string"
          },
          "title": "Prior Negative Cases",
          "type": "array"
        },
        "prior_negative_record_ids": {
          "items": {
            "type": "string"
          },
          "title": "Prior Negative Record Ids",
          "type": "array"
        },
        "prior_positive_cases": {
          "items": {
            "type": "string"
          },
          "title": "Prior Positive Cases",
          "type": "array"
        },
        "prior_positive_record_ids": {
          "items": {
            "type": "string"
          },
          "title": "Prior Positive Record Ids",
          "type": "array"
        },
        "provenance": {
          "items": {
            "$ref": "#/$defs/Provenance"
          },
          "title": "Provenance",
          "type": "array"
        },
        "rank": {
          "title": "Rank",
          "type": "integer"
        },
        "source_urls": {
          "items": {
            "type": "string"
          },
          "title": "Source Urls",
          "type": "array"
        },
        "thesis": {
          "title": "Thesis",
          "type": "string"
        },
        "ticker": {
          "title": "Ticker",
          "type": "string"
        },
        "why_now": {
          "title": "Why Now",
          "type": "string"
        }
      },
      "required": [
        "rank",
        "ticker",
        "company_name",
        "path_type",
        "thesis",
        "why_now"
