      "type": "object"
    },
    "CandidateExpansionPath": {
      "enum": [
        "SINGLE_EVENT",
        "THEME_FORMATION",
        "BENEFICIARY_DISCOVERY",
        "CONTINUATION"
      ],
      "title": "CandidateExpansionPath",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "format": "date-time",
